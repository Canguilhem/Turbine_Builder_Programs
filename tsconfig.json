{
  "compilerOptions": {
    "types": ["node", "mocha", "chai"],
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["tests/**/*.ts", "migrations/**/*.ts", "target/types/**/*.ts"]
}
